# .env.example — copy to .env and fill in values
# ==================================================

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-for-development-only
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# Database path
# SQLite (Local Development)
DATABASE_URL=sqlite+aiosqlite:///./saferoute.db
# For PostgreSQL (Production):
# DATABASE_URL=postgresql+asyncpg://saferoute_user:changeme@localhost:5432/saferoute

# DB Connection Pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30

# Feature Flags
ENABLE_PG=false
ENABLE_DUAL_WRITE=false
ENABLE_PHOTO_STORAGE=false
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://10.0.2.2:8000

# SOS Push Notifications (Firebase Admin SDK)
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk.json

# SOS SMS Fallback
# Options: fast2sms | twilio
SMS_PROVIDER=fast2sms
SMS_API_KEY=

# Twilio (only if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Fast2SMS (only if SMS_PROVIDER=fast2sms)
FAST2SMS_SENDER_ID=SFRTST

# Photo Storage
PHOTO_STORAGE_BACKEND=disk
PHOTO_UPLOAD_DIR=uploads/photos

# SOS Dispatch (leave empty for local-only mode)
SOS_DISPATCH_WEBHOOK_URL=
