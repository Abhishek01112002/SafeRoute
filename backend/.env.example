# .env.example — copy to .env and fill in values
# ==================================================

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-hex-chars-from-python-secrets-token-hex-32
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# Database path
# SQLite (Local Development)
DATABASE_URL=sqlite+aiosqlite:///./saferoute.db
# For PostgreSQL (Production):
# DATABASE_URL=postgresql+asyncpg://saferoute_user:changeme@localhost:5432/saferoute

# DB Connection Pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30

# Feature Flags
ENABLE_PG=false
ENABLE_DUAL_WRITE=false
ENABLE_PHOTO_STORAGE=false
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://10.0.2.2:8000

# SOS Push Notifications (Firebase Admin SDK)
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk.json

# SOS SMS Fallback (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALWAYS_SEND_SMS=false

# Photo Storage (Legacy — disk-based)
PHOTO_STORAGE_BACKEND=disk
PHOTO_UPLOAD_DIR=uploads/photos

# SOS Dispatch (leave empty for local-only mode)
SOS_DISPATCH_WEBHOOK_URL=
SOS_WORKER_ENABLED=true
SOS_RETRY_INTERVAL_SECONDS=30
SOS_DELIVERY_TTL_SECONDS=7200
SOS_ESCALATE_AFTER_SECONDS=1800
SOS_EXPIRE_RESPONSE_AFTER_SECONDS=14400
SOS_PROVIDER_FAILURE_THRESHOLD=3
SOS_PROVIDER_CIRCUIT_COOLDOWN_SECONDS=60
MESH_SECRET_MASTER_KEY=replace-with-64-hex-chars-from-python-secrets-token-hex-32
MESH_KEY_GRACE_DAYS=7


# ---------------------------------------------------------------------------
# Identity v3.0 — Digital Identity System
# ---------------------------------------------------------------------------

# Redis (caching, rate limiting, session blacklist)
REDIS_URL=redis://localhost:6379/0

# MinIO / S3 Object Storage (tourist photos, document scans)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=saferoute_access
MINIO_SECRET_KEY=saferoute_secret_change_me
MINIO_BUCKET=saferoute-media
MINIO_USE_SSL=false

# TUID Generation Salt (MUST match mobile identity_service.dart)
TUID_SALT=SR_IDENTITY_V1_UTTARAKHAND_2025

# QR JWT (Identity Verification QR Code)
QR_JWT_EXPIRY_DAYS=365

# Photo Upload Constraints
PHOTO_MAX_SIZE_MB=5
